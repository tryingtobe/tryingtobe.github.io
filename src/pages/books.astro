---
import BookLayout from '../layouts/BookLayout.astro';
import { books } from '../data/books';

const monthOrder = [...new Set(books.map((b) => b.month))];
const grouped = monthOrder.map((month) => ({
	month,
	items: books.filter((b) => b.month === month),
})).reverse();
---
<BookLayout title="Books" description="A monthly reading log">
	<div class="reading-log">
		{grouped.map((entry) => (
			<section class="month-block">
				<h2 class="month-title">{entry.month}</h2>
				<ul class="book-list">
					{entry.items.map((book) => (
						<li class="book-item">
							<a href={`/books/${book.slug}`} class="book-link">
								<img
									src={book.coverUrl || `https://covers.openlibrary.org/b/isbn/${book.isbn}-M.jpg`}
									alt={`Cover of ${book.title}`}
									class="book-cover"
									loading="lazy"
								/>
								<div class="book-info">
									<div class="book-title">{book.title}</div>
									<div class="book-author">by {book.author}</div>
									<div class="book-rating">★ {book.rating.toFixed(2)}</div>
								</div>
							</a>
						</li>
					))}
				</ul>
			</section>
		))}
	</div>
</BookLayout>

<style>
	.reading-log { display: flex; flex-direction: column; gap: 40px; }
	.month-title {
		font-family: 'EB Garamond', serif;
		font-size: 26px;
		color: var(--gold);
		border-bottom: 1px solid var(--line);
		padding-bottom: 8px;
		margin-bottom: 16px;
	}
	.book-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 20px; }
	.book-item { padding: 12px 0; border-bottom: 1px dashed var(--line); }
	.book-link {
		text-decoration: none;
		color: inherit;
		display: flex;
		gap: 8px;
		align-items: flex-start;
		transition: opacity .2s;
	}
	.book-link:hover { opacity: 0.75; }
	.book-cover {
		width: 60px;
		height: 90px;
		object-fit: cover;
		border-radius: 4px;
		background: var(--line);
		flex-shrink: 0;
	}
	.book-info { flex: 1; }
	.book-title { font-size: 17px; font-weight: 400; font-family: 'EB Garamond', serif; }
	.book-author { color: var(--muted); font-size: 14px; margin-bottom: 4px; }
	.book-rating { color: var(--gold); }
</style>
