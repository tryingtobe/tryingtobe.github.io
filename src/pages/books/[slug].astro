---
import BookLayout from '../../layouts/BookLayout.astro';
import { books } from '../../data/books';

export function getStaticPaths() {
	return books.map((book) => ({
		params: { slug: book.slug },
		props: { book },
	}));
}

const { book } = Astro.props;
const coverSrc = book.coverUrl || `https://covers.openlibrary.org/b/isbn/${book.isbn}-L.jpg`;
---
<BookLayout title={book.title} description={`by ${book.author}`}>
	<img
		src={coverSrc}
		alt={`Cover of ${book.title}`}
		class="cover-large"
	/>
	<div class="center-block">
		<p class="meta-line">★ {book.rating.toFixed(2)} <span class="sep">|</span> {book.month}</p>
		{book.quote && <blockquote class="book-quote">"{book.quote}"</blockquote>}
	</div>
	{book.notes && <p class="notes">{book.notes}</p>}
</BookLayout>

<style>
	.cover-large {
		display: block;
		max-width: 220px;
		width: 100%;
		height: auto;
		border-radius: 6px;
		margin: 0 auto 28px;
	}
	.center-block {
		text-align: center;
		max-width: 540px;
		margin: 0 auto;
	}
	.meta-line {
		color: var(--gold);
		font-size: 16px;
		margin-bottom: 24px;
	}
	.meta-line .sep {
		color: var(--gold);
		margin: 0 20px;
	}
	.book-quote {
		font-family: 'Cormorant Garamond', serif;
		font-style: italic;
		font-size: 1.4rem;
		line-height: 1.4;
		margin: 24px auto;
		color: var(--text);
		border-left: none;
		padding-left: 0;
	}
	.notes {
		max-width: 540px;
		margin: 0 auto;
	}
</style>
