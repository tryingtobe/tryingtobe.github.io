---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
<head>
<BaseHead title={`You're in -- ${SITE_TITLE}`} description="Thanks for subscribing to Bluebound Ink." />
</head>
<body>
<Header />
<main>
<div class="wrap thanks-wrap">
<span class="sparkle">&#10022;</span>
<h1 class="thanks-title display">Thank you for wandering in.</h1>
<p class="thanks-body">
You're bound to Bluebound Ink now. Every new story, every stray thought --
it'll find its way to you, quietly, the way it was meant to. No noise, just words when they're ready.
</p>
<a href="/" class="thanks-link">&larr; Back to where it all wanders from</a>
</div>
</main>
<Footer />
</body>
</html>

<style>
.thanks-wrap {
text-align: center;
padding: 100px 24px 120px;
max-width: 560px;
margin: 0 auto;
}
.sparkle {
display: block;
color: var(--gold);
font-size: 22px;
margin-bottom: 20px;
}
.thanks-title {
font-size: clamp(36px, 6vw, 52px);
line-height: 1.05;
margin: 0 0 20px;
}
.thanks-body {
color: var(--muted);
font-size: 18px;
font-style: italic;
line-height: 1.6;
margin-bottom: 40px;
}
.thanks-link {
color: var(--gold);
font-style: italic;
font-size: 16px;
text-decoration: none;
}
.thanks-link:hover {
text-decoration: underline;
}
</style>

