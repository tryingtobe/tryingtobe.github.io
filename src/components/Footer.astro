<footer>
	<div class="wrap">
		<span class="fi display">Bluebound <em>Ink</em></span>
		<span class="sep">—</span>
		bound in blue, written in ink. © {new Date().getFullYear()}
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--line);
		padding: 36px 0;
		text-align: center;
		color: var(--faint);
		font-size: 15px;
	}
	.fi { color: var(--gold); }
	.fi em { font-style: italic; }
	.sep { margin: 0 8px; }
</style>
